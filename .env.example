# Server
PORT=3000
HOST=0.0.0.0

# Tally Connection
# For LOCAL mode: keep 127.0.0.1
# For LAN mode: change to Tally PC's IP e.g. 192.168.1.100
TALLY_HOST=127.0.0.1
TALLY_PORT=9011
TALLY_TIMEOUT_MS=30000

# Tally Company & Filters
TALLY_COMPANY=Your Exact Company Name
TALLY_LEDGER_GROUP=Sundry Debtors
TALLY_SALESMAN=
TALLY_LEDGER_REPORT=List of Accounts
TALLY_REQUEST_STYLE=legacy
TALLY_USERNAME=
TALLY_PASSWORD=

# Security
# Leave blank to disable API key auth (dashboard still works)
API_KEY=

# Remote Access via ngrok
# Get a free token at https://ngrok.com
ENABLE_NGROK=false
NGROK_AUTHTOKEN=

# Export
# Leave blank to use ~/TallyBridge-exports/
EXPORT_PATH=

# CORS
ALLOWED_ORIGINS=*
